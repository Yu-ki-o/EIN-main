# Python/cache artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Local environments and editor state
.env
.env.*
.venv/
venv/
env/
.idea/
.vscode/
.agents/
.codex/

# Large local data/model artifacts
dataset/
datasets/
data/
word2vec/

*.pt
*.pth
*.pth.*
*.ckpt
*.model
*.npy
*.npz
*.pkl

# Do not track experiment records or generated experiment files
experiments/

# Always keep project configs and model source files trackable.
!configs/
!configs/**
!model/
!model/**

# Ignore cache files inside model source directories.
model/**/__pycache__/
model/**/*.py[cod]

# OS files
.DS_Store
Thumbs.db