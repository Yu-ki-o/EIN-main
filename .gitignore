# Python/cache artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Local environments and editor state
.env
.env.*
.venv/
venv/
env/
.idea/
.vscode/
.agents/
.codex/

# Large local data/model artifacts
dataset/
word2vec/
*.pt
*.pth
*.pth.*
*.ckpt
*.model
*.npy

# Always keep project configs and model source files trackable.
!configs/
!configs/**
!model/
!model/**
model/**/__pycache__/
model/**/*.py[cod]

# Experiment outputs: keep lightweight summaries/visualizations, ignore runs.
experiments/**/seed_*/
experiments/**/*.log
experiments/**/best_model*

# OS files
.DS_Store
Thumbs.db
